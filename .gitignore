# See https://help.github.com/articles/ignoring-files/

# ─── Dependencies ───────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── Production / build ─────────────────────────────────────────────────────
/build
/dist

# ─── Environment variables ──────────────────────────────────────────────────
# Never commit secrets. Commit .env.example as a template if needed.
.env
.env.*
!.env.example

# ─── Vercel ─────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ─────────────────────────────────────────────────────────────
*.tsbuildinfo

# Note: next-env.d.ts is generated by Next.js but should be committed.

# ─── Testing ────────────────────────────────────────────────────────────────
/coverage
/.nyc_output

# ─── Linting / tooling caches ─────────────────────────────────────────────────
.eslintcache
.stylelintcache
.turbo

# ─── Debug logs ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# VS Code — ignore local settings, keep shared config if added later
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ─── Certificates / keys ──────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.local
