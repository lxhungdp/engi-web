# Copy to .env.local for local dev. On Vercel: Settings → Environment Variables (Production + Preview).
# Do NOT commit .env.local.

# Sanity — https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Public site URL (sitemap, Open Graph). Use your Vercel URL until you have a custom domain.
NEXT_PUBLIC_SITE_URL=https://argosdyne.vercel.app

# Optional: Viewer token for draft/preview (server-only — no NEXT_PUBLIC_ prefix)
# SANITY_API_READ_TOKEN=
